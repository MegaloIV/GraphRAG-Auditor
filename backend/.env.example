# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# ── Groq (extracción rápida) ─────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI (auditoría + RAGAS + embeddings) ──────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── CrossRef / Unpaywall ─────────────────────────────────────────────────────
CROSSREF_EMAIL=

# ── Neo4j (grafo de conocimiento) ────────────────────────────────────────────
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── Supabase Postgres (pgvector: tabla papers_chunks + auditoria_progreso) ───
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ── Supabase Storage (PDFs, markdown, resultados) ────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=graphrag-auditor

# ── Ingesta ──────────────────────────────────────────────────────────────────
MAX_PDF_SIZE_MB=10

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
